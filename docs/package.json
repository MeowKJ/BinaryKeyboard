{
  "name": "binarykeyboard-docs",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "sync-changelog": "node ./scripts/sync-changelog.mjs",
    "predev": "pnpm run sync-changelog",
    "dev": "vitepress dev --host 0.0.0.0 --port 5174 --no-open",
    "prebuild": "pnpm run sync-changelog",
    "build": "vitepress build",
    "prepreview": "pnpm run sync-changelog",
    "preview": "vitepress preview --host 0.0.0.0 --port 5174"
  },
  "devDependencies": {
    "vitepress": "^1.6.4"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "0.25.0",
      "postcss": "8.5.15",
      "rollup": "4.59.0",
      "vite": "6.4.3"
    }
  }
}
