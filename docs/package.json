  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=24",
    "pnpm": ">=11.9.0"
  },
  "scripts": {
    "sync-changelog": "node ./scripts/sync-changelog.mjs",
