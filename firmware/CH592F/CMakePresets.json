{
  "version": 3,
  "cmakeMinimumRequired": { "major": 3, "minor": 21, "patch": 0 },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "toolchainFile": "${sourceDir}/cmake/toolchain-ch59x.cmake",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      },
      "environment": {
        "PATH": "/opt/homebrew/bin:/usr/local/bin:$penv{PATH}"
      }
    },
    {
      "name": "model-5key",
      "hidden": true,
      "cacheVariables": {
        "KBD_MODEL": "5KEY"
      }
    },
    {
      "name": "debug",
      "displayName": "Debug",
      "description": "Debug build with -Og -g3",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "release",
      "displayName": "Release (size)",
      "description": "Size-optimized build with -Os",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "MinSizeRel"
      }
    },
    {
      "name": "debug-5key",
      "displayName": "Debug (5KEY)",
      "description": "Debug build with 5KEY model naming",
      "inherits": ["debug", "model-5key"]
    },
    {
      "name": "release-5key",
      "displayName": "Release (size, 5KEY)",
      "description": "Size-optimized build with 5KEY model naming",
      "inherits": ["release", "model-5key"]
    }
  ],
  "buildPresets": [
    { "name": "debug",   "configurePreset": "debug" },
    { "name": "release", "configurePreset": "release" },
    { "name": "debug-5key", "configurePreset": "debug-5key" },
    { "name": "release-5key", "configurePreset": "release-5key" }
  ]
}
