component BigButton inherits Rectangle {
    in property <string> label;
    in property <brush> accent: #2e8b57;
    in property <bool> enabled: true;
    callback clicked;

    height: 44px;
    border-radius: 14px;
    background: touch.pressed && root.enabled
        ? root.accent.darker(0.25)
        : touch.has-hover && root.enabled
            ? root.accent.darker(0.1)
            : root.accent;
    opacity: root.enabled ? 1.0 : 0.35;
    drop-shadow-blur: root.enabled && touch.has-hover ? 10px : 0px;
    drop-shadow-color: root.accent.with-alpha(0.3);
    drop-shadow-offset-y: root.enabled && touch.has-hover ? 3px : 0px;

    animate background { duration: 120ms; easing: ease; }
    animate opacity { duration: 200ms; }
    animate drop-shadow-blur { duration: 200ms; easing: ease-out; }
    animate drop-shadow-offset-y { duration: 200ms; easing: ease-out; }

    touch := TouchArea {
        enabled: root.enabled;
        clicked => { root.clicked(); }
        mouse-cursor: root.enabled ? pointer : default;
    }

    Text {
        text: root.label;
        color: #fffaf6;
        font-size: 15px;
        font-weight: 800;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

component SmallButton inherits Rectangle {
    in property <string> label;
    in property <brush> accent: #3d2b1f;
    in property <bool> enabled: true;
    callback clicked;

    height: 28px;
    border-radius: 10px;
    background: touch.pressed && root.enabled
        ? root.accent.darker(0.25)
        : touch.has-hover && root.enabled
            ? root.accent.darker(0.1)
            : root.accent;
    opacity: root.enabled ? 1.0 : 0.35;

    animate background { duration: 120ms; easing: ease; }
    animate opacity { duration: 200ms; }

    touch := TouchArea {
        enabled: root.enabled;
        clicked => { root.clicked(); }
        mouse-cursor: root.enabled ? pointer : default;
    }

    Text {
        text: root.label;
        color: #fffaf6;
        font-size: 11px;
        font-weight: 700;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

component IconButton inherits Rectangle {
    in property <string> icon: "⧉";
    in property <bool> enabled: true;
    callback clicked;

    width: 24px;
    height: 24px;
    border-radius: 8px;
    background: touch.pressed && root.enabled
        ? #e6ddd4
        : touch.has-hover && root.enabled
            ? #f2ebe3
            : transparent;
    border-width: 1px;
    border-color: touch.has-hover && root.enabled ? #dbcab8 : transparent;
    opacity: root.enabled ? 1.0 : 0.35;

    animate background { duration: 120ms; easing: ease; }
    animate border-color { duration: 120ms; easing: ease; }
    animate opacity { duration: 200ms; }

    touch := TouchArea {
        enabled: root.enabled;
        clicked => { root.clicked(); }
        mouse-cursor: root.enabled ? pointer : default;
    }

    Text {
        text: root.icon;
        color: #70584b;
        font-size: 12px;
        font-weight: 800;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

export component AppWindow inherits Window {
    in-out property <int> cat-mood: 0;
    in-out property <string> chip-name: "未识别";
    in-out property <string> chip-category: "等待检测";
    in-out property <string> chip-family: "";
    in-out property <string> firmware-name: "未选择";
    in-out property <string> firmware-path: "";
    in-out property <bool> has-firmware: false;
    in-out property <bool> busy: false;
    in-out property <string> log-title: "准备就绪";
    in-out property <string> log-text: "欢迎使用 MeowISP~";
    in-out property <string> status-text: "Ready";
    in-out property <bool> show-permission-bar: false;
    in-out property <bool> udev-installed: false;
    in-out property <bool> progress-visible: false;
    in-out property <int> progress-value: 0;
    in-out property <string> progress-label: "等待操作";
    in-out property <bool> show-success: false;
    in-out property <string> success-title: "刷写完成";
    in-out property <string> success-text: "";

    callback request-detect-chip();
    callback request-pick-bin();
    callback request-flash-bin();
    callback request-verify-bin();
    callback request-erase-code();
    callback request-erase-data();
    callback request-fix-permission();
    callback request-remove-permission();
    callback request-copy-log();
    callback request-dismiss-success();

    title: "MeowISP";
    width: 392px;
    height: 520px;
    background: #f5efe7;

    Rectangle {
        width: 100%;
        height: 100%;
        background: @linear-gradient(165deg, #f7f1e9 0%, #f0e6da 50%, #f8f4ef 100%);

        VerticalLayout {
            padding: 10px;
            spacing: 8px;

            Rectangle {
                height: 86px;
                border-radius: 18px;
                background: @linear-gradient(135deg, #ffd4a8 0%, #ffb88c 45%, #ffc9a8 100%);
                drop-shadow-blur: 8px;
                drop-shadow-color: #d4a07018;
                drop-shadow-offset-y: 2px;

                VerticalLayout {
                    padding: 10px;
                    spacing: 6px;

                    HorizontalLayout {
                        spacing: 8px;

                        Rectangle {
                            width: 32px;
                            height: 32px;

                            Image {
                                source: root.cat-mood == 1
                                    ? @image-url("../../../assets/cat_face_3d.png")
                                    : root.cat-mood == 2
                                        ? @image-url("../../../assets/smiling_cat_with_heart-eyes_3d.png")
                                        : root.cat-mood == 3
                                            ? @image-url("../../../assets/crying_cat_3d.png")
                                            : @image-url("../../../assets/grinning_cat_3d.png");
                                width: cat-touch.has-hover ? 34px : 30px;
                                height: cat-touch.has-hover ? 34px : 30px;

                                animate width { duration: 200ms; easing: ease-out; }
                                animate height { duration: 200ms; easing: ease-out; }

                                cat-touch := TouchArea {
                                    mouse-cursor: pointer;
                                }
                            }
                        }

                        Text {
                            text: "MeowISP";
                            color: #2b1810;
                            font-size: 19px;
                            font-weight: 900;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                        }

                        Rectangle {
                            height: 22px;
                            min-width: 54px;
                            border-radius: 11px;
                            background: root.busy ? #7b5d4f : #f7ede1;
                            border-width: root.busy ? 0px : 1px;
                            border-color: #e2c4ad;

                            HorizontalLayout {
                                padding-left: 8px;
                                padding-right: 8px;
                                alignment: center;

                                Text {
                                    text: root.busy ? "处理中" : root.status-text;
                                    color: root.busy ? #fff7f0 : #85593d;
                                    font-size: 10px;
                                    font-weight: 700;
                                }
                            }
                        }
                    }

                    HorizontalLayout {
                        alignment: center;
                        spacing: 6px;

                        Rectangle {
                            height: 24px;
                            min-width: 68px;
                            border-radius: 12px;
                            background: root.chip-category == "有线款" ? #2f8f5b
                                : root.chip-category == "无线款" ? #4576d6
                                : root.chip-category == "其他 WCH" ? #7c6ac8
                                : #c8b8a8;

                            HorizontalLayout {
                                padding-left: 10px;
                                padding-right: 10px;
                                alignment: center;

                                Text {
                                    text: root.chip-category;
                                    color: white;
                                    font-size: 10px;
                                    font-weight: 800;
                                }
                            }
                        }

                        Rectangle {
                            height: 24px;
                            min-width: 58px;
                            border-radius: 12px;
                            background: #fff5eb;
                            border-width: 1px;
                            border-color: #e9cdb4;

                            HorizontalLayout {
                                padding-left: 10px;
                                padding-right: 10px;
                                alignment: center;

                                Text {
                                    text: root.chip-name;
                                    color: #704936;
                                    font-size: 10px;
                                    font-weight: 800;
                                }
                            }
                        }
                    }

                    Text {
                        text: root.chip-family != "" ? root.chip-family : "BinaryKeyboard first-flash companion";
                        color: #775548;
                        font-size: 10px;
                        horizontal-alignment: center;
                    }
                }
            }

            if root.show-permission-bar: Rectangle {
                height: 30px;
                border-radius: 10px;
                background: #fff0e0;
                border-width: 1px;
                border-color: #f0c080;

                HorizontalLayout {
                    padding-left: 10px;
                    padding-right: 6px;
                    spacing: 6px;

                    Text {
                        text: "USB 权限未配置";
                        color: #8a5a20;
                        font-size: 10px;
                        font-weight: 600;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                    }

                    SmallButton {
                        width: 80px;
                        label: "自动配置";
                        accent: #d48030;
                        clicked => { root.request-fix-permission(); }
                    }
                }
            }

            Rectangle {
                height: 54px;
                border-radius: 14px;
                background: #fff8f1;
                border-width: 1px;
                border-color: #eddccd;

                HorizontalLayout {
                    padding-left: 10px;
                    padding-right: 8px;
                    spacing: 8px;

                    VerticalLayout {
                        alignment: center;
                        horizontal-stretch: 1;

                        Text {
                            text: root.chip-name == "未识别" ? "等待识别芯片" : root.chip-name;
                            color: #2e211d;
                            font-size: 13px;
                            font-weight: 800;
                            overflow: elide;
                        }

                        Text {
                            text: root.chip-category == "等待检测" ? "设备接入后可手动识别，也可直接刷写" : root.chip-category + " · " + root.chip-family;
                            color: #7a675d;
                            font-size: 10px;
                            overflow: elide;
                        }
                    }

                    SmallButton {
                        width: 82px;
                        label: "识别芯片";
                        accent: #3d2b1f;
                        enabled: !root.busy;
                        clicked => { root.request-detect-chip(); }
                    }
                }
            }

            Rectangle {
                height: 48px;
                border-radius: 14px;
                background: #f0ecff;

                HorizontalLayout {
                    padding-left: 10px;
                    padding-right: 6px;
                    spacing: 6px;

                    VerticalLayout {
                        alignment: center;
                        horizontal-stretch: 1;

                        Text {
                            text: root.has-firmware ? root.firmware-name : "未选择固件";
                            color: #2a2050;
                            font-size: 12px;
                            font-weight: 700;
                            overflow: elide;
                        }

                        if root.has-firmware: Text {
                            text: root.firmware-path;
                            color: #6d6190;
                            font-size: 9px;
                            overflow: elide;
                        }
                    }

                    SmallButton {
                        width: 72px;
                        label: "选择 BIN";
                        accent: #6b5098;
                        enabled: !root.busy;
                        clicked => { root.request-pick-bin(); }
                    }
                }
            }

            HorizontalLayout {
                spacing: 6px;

                BigButton {
                    horizontal-stretch: 3;
                    label: "刷写固件";
                    accent: #2e8b57;
                    enabled: !root.busy && root.has-firmware;
                    clicked => { root.request-flash-bin(); }
                }

                BigButton {
                    horizontal-stretch: 2;
                    label: "校验";
                    accent: #3a7ca5;
                    enabled: !root.busy && root.has-firmware;
                    clicked => { root.request-verify-bin(); }
                }
            }

            HorizontalLayout {
                spacing: 6px;

                SmallButton {
                    horizontal-stretch: 1;
                    label: "清 Code";
                    accent: #c0784a;
                    enabled: !root.busy;
                    clicked => { root.request-erase-code(); }
                }

                SmallButton {
                    horizontal-stretch: 1;
                    label: "清 Data";
                    accent: #b8885a;
                    enabled: !root.busy;
                    clicked => { root.request-erase-data(); }
                }

                if root.udev-installed: SmallButton {
                    horizontal-stretch: 1;
                    label: "清除权限";
                    accent: #a05050;
                    enabled: !root.busy;
                    clicked => { root.request-remove-permission(); }
                }
            }

            Rectangle {
                vertical-stretch: 1;
                border-radius: 16px;
                background: #fffaf6;
                drop-shadow-blur: 4px;
                drop-shadow-color: #00000006;
                drop-shadow-offset-y: 1px;

                VerticalLayout {
                    padding: 10px;
                    spacing: 6px;

                    HorizontalLayout {
                        spacing: 5px;

                        Image {
                            source: root.cat-mood == 2
                                ? @image-url("../../../assets/smiling_cat_with_heart-eyes_3d.png")
                                : root.cat-mood == 3
                                    ? @image-url("../../../assets/crying_cat_3d.png")
                                    : root.cat-mood == 1
                                        ? @image-url("../../../assets/cat_face_3d.png")
                                        : @image-url("../../../assets/grinning_cat_3d.png");
                            width: 16px;
                            height: 16px;
                        }

                        Text {
                            text: "活动";
                            color: #2e211d;
                            font-size: 13px;
                            font-weight: 800;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                        }

                        IconButton {
                            icon: "⧉";
                            enabled: root.log-text != "";
                            clicked => { root.request-copy-log(); }
                        }
                    }

                    Text {
                        text: root.progress-visible ? root.progress-label : root.log-title;
                        color: #5b473c;
                        font-size: 11px;
                        font-weight: 700;
                    }

                    Rectangle {
                        height: 8px;
                        border-radius: 4px;
                        background: #efe4d8;

                        Rectangle {
                            width: parent.width * root.progress-value / 100;
                            height: parent.height;
                            border-radius: 4px;
                            background: @linear-gradient(90deg, #ffb37c 0%, #ff8f67 100%);
                        }
                    }

                    Text {
                        text: root.progress-visible ? root.progress-value + "%" : "点击按钮开始操作，终端会同步输出底层 wchisp 调试日志。";
                        color: #8b7769;
                        font-size: 10px;
                    }

                    Rectangle {
                        height: 1px;
                        background: #e8d8ca;
                    }

                    Flickable {
                        vertical-stretch: 1;

                        Rectangle {
                            width: parent.width;
                            min-height: 128px;
                            border-radius: 12px;
                            background: #2b211d;

                            Text {
                                x: 10px;
                                y: 10px;
                                width: parent.width - 20px;
                                text: root.log-text;
                                color: #f8efe8;
                                font-size: 11px;
                                wrap: word-wrap;
                            }
                        }
                    }
                }
            }
        }

        if root.show-success: Rectangle {
            width: 100%;
            height: 100%;
            background: #2c1e16aa;

            Rectangle {
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                width: 250px;
                height: 240px;
                border-radius: 22px;
                background: #fff7f0;
                drop-shadow-blur: 18px;
                drop-shadow-color: #00000020;
                drop-shadow-offset-y: 8px;

                VerticalLayout {
                    padding: 18px;
                    spacing: 10px;
                    alignment: center;

                    Image {
                        source: @image-url("../../../assets/smiling_cat_with_heart-eyes_3d.png");
                        width: 56px;
                        height: 56px;
                    }

                    Text {
                        text: root.success-title;
                        color: #2f211b;
                        font-size: 20px;
                        font-weight: 900;
                        horizontal-alignment: center;
                    }

                    Text {
                        text: root.success-text;
                        color: #735c4d;
                        font-size: 11px;
                        wrap: word-wrap;
                        horizontal-alignment: center;
                    }

                    Rectangle {
                        height: 1px;
                        background: #ead7c8;
                    }

                    BigButton {
                        width: 100%;
                        label: "太好了";
                        accent: #2f8f5b;
                        clicked => { root.request-dismiss-success(); }
                    }
                }
            }
        }
    }
}
