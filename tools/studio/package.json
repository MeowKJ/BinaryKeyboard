{
  "name": "meowkeyboard-studio",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "sync-versions": "node ./scripts/sync-versions.mjs",
    "predev": "pnpm run sync-versions",
    "prebuild": "pnpm run sync-versions",
    "pretype-check": "pnpm run sync-versions",
    "dev": "vite --host 0.0.0.0",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview --host 0.0.0.0",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:electron-renderer": "cross-env VITE_BASE_URL=./ vite build",
    "build:electron-main": "tsc -p tsconfig.electron.json",
    "build:electron": "run-s sync-versions build:electron-renderer build:electron-main",
    "dist:mac": "pnpm run build:electron && electron-builder --mac",
    "dist:win": "pnpm run build:electron && electron-builder --win"
  },
  "build": {
    "appId": "com.binarykeyboard.studio",
    "productName": "BinaryKeyboard Studio",
    "copyright": "Copyright © 2025 喵喵的帕斯",
    "files": [
      "dist/**",
      "dist-electron/**"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "dmg": {
      "title": "BinaryKeyboard Studio",
      "window": {
        "width": 540,
        "height": 280
      }
    },
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64",
            "ia32",
            "arm64"
          ]
        }
      ]
    },
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}"
  },
  "dependencies": {
    "@primeuix/themes": "^1.0.0",
    "gsap": "^3.14.2",
    "pinia": "^3.0.1",
    "primeflex": "^4.0.0",
    "primeicons": "^7.0.0",
    "primevue": "^4.3.1",
    "vue": "^3.5.13",
    "vue-draggable-plus": "^0.6.1"
  },
  "devDependencies": {
    "@primevue/auto-import-resolver": "^4.3.1",
    "@tsconfig/node22": "^22.0.0",
    "@types/node": "^22.13.4",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/tsconfig": "^0.7.0",
    "cross-env": "^7.0.3",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8",
    "npm-run-all2": "^8.0.4",
    "typescript": "~5.7.3",
    "unplugin-vue-components": "^28.4.1",
    "vite": "^6.4.1",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-vue-devtools": "^8.1.0",
    "vitest": "^4.1.0",
    "vue-tsc": "^3.2.5",
    "workbox-window": "^7.4.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ],
    "overrides": {
      "@babel/helpers": "7.26.10",
      "@rollup/plugin-babel": "7.0.0",
      "@rollup/plugin-node-resolve": "16.0.3",
      "@rollup/plugin-replace": "6.0.3",
      "@rollup/plugin-terser": "1.0.0",
      "brace-expansion@2.0.1": "2.0.2",
      "minimatch@9.0.5": "9.0.7",
      "rollup": "4.59.0",
      "serialize-javascript": "7.0.3"
    }
  }
}
