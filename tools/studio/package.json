{
  "name": "meowkeyboard-studio",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "main": "dist-electron/main.js",
  "engines": {
    "node": ">=24",
    "pnpm": ">=11.9.0"
  },
  "scripts": {
    "sync-versions": "node ./scripts/sync-versions.mjs",
    "predev": "pnpm run sync-versions",
    "prebuild": "pnpm run sync-versions",
    "pretype-check": "pnpm run sync-versions",
    "dev": "vite --host 0.0.0.0",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview --host 0.0.0.0",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "test": "vitest run",
    "test:watch": "vitest",
    "score:dataflash": "node ./scripts/score-dataflash-visual.cjs",
    "build:electron-renderer": "cross-env VITE_BASE_URL=./ vite build",
    "build:electron-main": "tsc -p tsconfig.electron.json",
    "build:electron": "run-s sync-versions build:electron-renderer build:electron-main",
    "dist:mac": "pnpm run build:electron && electron-builder --mac",
    "dist:win": "pnpm run build:electron && electron-builder --win"
  },
  "build": {
    "appId": "com.binarykeyboard.studio",
    "productName": "BinaryKeyboard Studio",
    "copyright": "Copyright © 2025 喵喵的帕斯",
    "files": [
      "dist/**",
      "dist-electron/**"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "dmg": {
      "title": "BinaryKeyboard Studio",
      "window": {
        "width": 540,
        "height": 280
      }
    },
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}"
  },
  "dependencies": {
    "@meowkj/fluent-emoji-assets": "^0.1.0",
    "@primeuix/themes": "^2.0.3",
    "d3-hierarchy": "^3.1.2",
    "gsap": "^3.15.0",
    "pinia": "^3.0.4",
    "pixi.js": "^8.19.0",
    "primeflex": "^4.0.0",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.5",
    "vue": "^3.5.39",
    "vue-draggable-plus": "^0.6.1"
  },
  "devDependencies": {
    "@primevue/auto-import-resolver": "^4.5.5",
    "@tsconfig/node24": "^24.0.4",
    "@types/d3-hierarchy": "^3.1.7",
    "@types/node": "^24.13.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/tsconfig": "^0.9.1",
    "cross-env": "^10.1.0",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "npm-run-all2": "^9.0.2",
    "typescript": "~5.9.3",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^6.4.3",
    "vite-plugin-pwa": "1.3.0",
    "vite-plugin-vue-devtools": "^7.7.10",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.3.5",
    "workbox-window": "7.4.1"
  }
}
