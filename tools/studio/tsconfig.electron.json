{
  "extends": "@tsconfig/node22/tsconfig.json",
  "include": ["electron"],
  "compilerOptions": {
    "noEmit": false,
    "outDir": "dist-electron",
    "rootDir": "electron",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["node"],
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.electron.tsbuildinfo"
  }
}
